<%- include('partials/header') %>

<div style="display: flex; gap: 30px; align-items: flex-start; margin-top: 20px;">
    <img src="<%= book.thumbnail %>" alt="<%= book.title %>" style="box-shadow: 0 4px 10px rgba(0,0,0,0.2); width: 200px; border-radius: 6px;">
    <div>
        <h1><%= book.title %></h1>
        <h3>👤 Author: <%= book.authors %></h3>
        <p style="line-height: 1.6; font-size: 16px;"><%= book.description %></p>
        
        <div style="margin-top: 30px;">
            <a href="/books/edit/<%= book.id %>" class="btn btn-primary">✏️ Edit Details</a>
            
            <form action="/books/delete/<%= book.id %>" method="POST" style="display: inline-block;" onsubmit="return confirm('Are you sure you want to delete this book?');">
                <button type="submit" class="btn btn-danger">🗑️ Delete Book</button>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>